#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

sem_t wrt;    
int data = 0;  

void *writer(void *arg)
{
    int id = *(int *)arg;

    sem_wait(&wrt); 

    data++;  
    printf("Writer %d is writing data = %d\n", id, data);
    sleep(1);

    sem_post(&wrt); 

    return NULL;
}

int main()
{
    pthread_t w[3];
    int id[3];

    sem_init(&wrt, 0, 1);

    for(int i = 0; i < 3; i++)
    {
        id[i] = i + 1;
        pthread_create(&w[i], NULL, writer, &id[i]);
    }

    for(int i = 0; i < 3; i++)
        pthread_join(w[i], NULL);

    sem_destroy(&wrt);

    return 0;
}
