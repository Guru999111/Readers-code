#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

sem_t mutex, wrt;
int read_count = 0;
int data = 0;

void *reader(void *arg)
{
    int id = *(int *)arg;

    sem_wait(&mutex);
    read_count++;

    if (read_count == 1)
        sem_wait(&wrt);

    sem_post(&mutex);

    printf("Reader %d is reading data = %d\n", id, data);
    sleep(1);

    sem_wait(&mutex);
    read_count--;

    if (read_count == 0)
        sem_post(&wrt);

    sem_post(&mutex);

    return NULL;
}

void *writer(void *arg)
{
    int id = *(int *)arg;

    sem_wait(&wrt);

    data++;
    printf("Writer %d is writing data = %d\n", id, data);
    sleep(1);

    sem_post(&wrt);

    return NULL;
}

int main()
{
    pthread_t r[5], w[2];
    int i, id[5];

    sem_init(&mutex, 0, 1);
    sem_init(&wrt, 0, 1);

    for (i = 0; i < 5; i++)
    {
        id[i] = i + 1;
        pthread_create(&r[i], NULL, reader, &id[i]);
    }

    for (i = 0; i < 2; i++)
    {
        pthread_create(&w[i], NULL, writer, &id[i]);
    }

    for (i = 0; i < 5; i++)
        pthread_join(r[i], NULL);

    for (i = 0; i < 2; i++)
        pthread_join(w[i], NULL);

    sem_destroy(&mutex);
    sem_destroy(&wrt);

    return 0;
}
